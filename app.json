{
  "expo": {
    "name": "Nest Junior Driver",
    "slug": "nest-junior-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "assets/sounds/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.itsmuse.nestjuniordriver",
      "infoPlist": {
        "NSCameraUsageDescription": "Nest Junior requires camera access to capture student boarding snapshots and provide secure live look-ins.",
        "NSMicrophoneUsageDescription": "Nest Junior requires microphone access to transmit cabin audio during live look-ins."
      }
    },
    "android": {
      "runtimeVersion": {
        "policy": "appVersion"
      },
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.itsmuse.nestjuniordriver",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDA8XVAaxYSh8A5tLO02T9sEJqhHN6EXkE"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/images/favicon.png"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/c9ef108f-6cbf-49ec-923c-3e408c246012"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/crashlytics",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff",
          "defaultChannelId": "ride_notifications",
          "sounds": [
            "./assets/sounds/new_follower1.wav",
            "./assets/sounds/ride_request2.mp3",
            "./assets/sounds/new_follower2.m4a"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-router",
        {
          "origin": "https://uber.dev/"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/yigezubisratgothic.ttf",
            "./assets/fonts/hiwua.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://uber.dev/"
      },
      "eas": {
        "projectId": "c9ef108f-6cbf-49ec-923c-3e408c246012"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
